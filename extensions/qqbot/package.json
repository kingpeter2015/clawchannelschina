{
  "name": "@openclaw-china/qqbot",
  "version": "2026.3.9-1",
  "type": "module",
  "description": "Moltbot QQ Bot channel plugin",
  "license": "MIT",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "skills"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "qqbot",
      "label": "QQ Bot",
      "selectionLabel": "QQ Bot",
      "docsPath": "/channels/qqbot",
      "blurb": "QQ 开放平台机器人消息",
      "aliases": [
        "qq"
      ],
      "order": 72
    },
    "install": {
      "npmSpec": "@openclaw-china/qqbot",
      "localPath": ".",
      "defaultChoice": "npm"
    }
  },
  "moltbot": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "qqbot",
      "label": "QQ Bot",
      "selectionLabel": "QQ Bot",
      "docsPath": "/channels/qqbot",
      "blurb": "QQ 开放平台机器人消息",
      "aliases": [
        "qq"
      ],
      "order": 72
    },
    "install": {
      "npmSpec": "@openclaw-china/qqbot",
      "localPath": ".",
      "defaultChoice": "npm"
    }
  },
  "clawdbot": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "qqbot",
      "label": "QQ Bot",
      "selectionLabel": "QQ Bot",
      "docsPath": "/channels/qqbot",
      "blurb": "QQ 开放平台机器人消息",
      "aliases": [
        "qq"
      ],
      "order": 72
    },
    "install": {
      "npmSpec": "@openclaw-china/qqbot",
      "localPath": ".",
      "defaultChoice": "npm"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "release": "npm run build && npm publish"
  },
  "dependencies": {
    "@clawchannelschina/shared": "workspace:*",
    "ffmpeg-static": "^5.3.0",
    "silk-wasm": "^3.7.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "moltbot": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "moltbot": {
      "optional": true
    }
  },
  "private": false
}

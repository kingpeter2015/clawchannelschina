{
  "name": "@openclaw-china/wecom",
  "version": "2026.3.9-1",
  "type": "module",
  "description": "Moltbot WeCom smart bot channel plugin",
  "license": "MIT",
  "files": [
    "dist",
    "moltbot.plugin.json",
    "clawdbot.plugin.json",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "wecom",
      "label": "WeCom",
      "selectionLabel": "WeCom (企业微信)",
      "docsPath": "/channels/wecom",
      "blurb": "企业微信智能机器人（Webhook / 长连接）",
      "aliases": [
        "wechatwork",
        "wework",
        "qywx"
      ],
      "order": 85
    },
    "install": {
      "npmSpec": "@openclaw-china/wecom",
      "localPath": ".",
      "defaultChoice": "npm"
    }
  },
  "moltbot": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "wecom",
      "label": "WeCom",
      "selectionLabel": "WeCom (企业微信)",
      "docsPath": "/channels/wecom",
      "blurb": "企业微信智能机器人（Webhook / 长连接）",
      "aliases": [
        "wechatwork",
        "wework",
        "qywx"
      ],
      "order": 85
    },
    "install": {
      "npmSpec": "@openclaw-china/wecom",
      "localPath": ".",
      "defaultChoice": "npm"
    }
  },
  "clawdbot": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "wecom",
      "label": "WeCom",
      "selectionLabel": "WeCom (企业微信)",
      "docsPath": "/channels/wecom",
      "blurb": "企业微信智能机器人（Webhook / 长连接）",
      "aliases": [
        "wechatwork",
        "wework",
        "qywx"
      ],
      "order": 85
    },
    "install": {
      "npmSpec": "@openclaw-china/wecom",
      "localPath": ".",
      "defaultChoice": "npm"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "release": "npm run build && npm publish",
    "release:patch": "npm run build && npm version patch && npm publish",
    "release:minor": "npm run build && npm version minor && npm publish",
    "release:major": "npm run build && npm version major && npm publish"
  },
  "dependencies": {
    "@clawchannelschina/shared": "workspace:2026.3.9-1",
    "@wecom/aibot-node-sdk": "^1.0.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "moltbot": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "moltbot": {
      "optional": true
    }
  },
  "private": false
}

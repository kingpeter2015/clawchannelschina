{
  "name": "@openclaw-china/channels",
  "version": "2026.3.9-1",
  "type": "module",
  "description": "Unified package for all Moltbot China channel plugins",
  "license": "MIT",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "moltbot.plugin.json",
    "clawdbot.plugin.json"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "npmSpec": "@openclaw-china/channels",
      "localPath": ".",
      "defaultChoice": "npm"
    }
  },
  "moltbot": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "npmSpec": "@openclaw-china/channels",
      "localPath": ".",
      "defaultChoice": "npm"
    }
  },
  "clawdbot": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "npmSpec": "@openclaw-china/channels",
      "localPath": ".",
      "defaultChoice": "npm"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@clawchannelschina/shared": "workspace:*",
    "@openclaw-china/dingtalk": "workspace:2026.3.9-1",
    "@openclaw-china/feishu-china": "workspace:2026.3.9-1",
    "@openclaw-china/qqbot": "workspace:2026.3.9-1",
    "@openclaw-china/wecom": "workspace:2026.3.9-1",
    "@openclaw-china/wecom-app": "workspace:2026.3.9-1"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "moltbot": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "moltbot": {
      "optional": true
    }
  }
}
